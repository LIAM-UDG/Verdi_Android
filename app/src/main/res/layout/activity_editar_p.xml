<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo1"
    tools:context=".NuevaP">

    <!-- Título -->

    <!-- Línea divisoria -->

    <Button
        android:id="@+id/btnEPEdiFoto"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="76dp"
        android:layout_marginTop="84dp"
        android:backgroundTint="@color/verdeM"
        android:text="Editar foto"
        android:textColor="@color/fondo1"
        app:layout_constraintStart_toEndOf="@+id/imgEPPlanta"
        app:layout_constraintTop_toBottomOf="@+id/etEPTitulo" />

    <TextView
        android:id="@+id/etEPTitulo"
        android:layout_width="231dp"
        android:layout_height="45dp"
        android:layout_marginLeft="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginRight="16dp"
        android:fontFamily="serif"
        android:text="Editar Planta"
        android:textColor="@color/verdeF"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.502"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Imagen de planta (placeholder) -->

    <!-- Botón Subir foto -->

    <!-- Etiqueta Nombre -->

    <!-- Campo Nombre -->

    <!-- Botón Seleccionar Planta -->

    <!-- Etiqueta Ambiente -->

    <!-- Spinner para seleccionar el ambiente -->

    <!-- Botón Continuar -->

    <View
        android:id="@+id/vEPlinea"
        android:layout_width="0dp"
        android:layout_height="2dp"
        android:layout_marginLeft="16dp"
        android:layout_marginTop="4dp"
        android:layout_marginRight="16dp"
        android:background="@color/verdeF"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/etEPTitulo" />

    <Spinner
        android:id="@+id/spnEPAmbiente"
        android:layout_width="0dp"
        android:layout_height="48sp"
        android:layout_marginStart="32dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="32dp"
        android:background="@drawable/rounded_spinner_background"
        android:entries="@array/ambientes_planta"
        android:popupBackground="@color/fondo2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/etEPAmbi" />

    <TextView
        android:id="@+id/etEPTipoP"
        android:layout_width="130dp"
        android:layout_height="24dp"
        android:layout_marginStart="32dp"
        android:layout_marginTop="440dp"
        android:text="Tipo de Planta"
        android:textColor="@color/verdeF"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/etEPAmbi"
        android:layout_width="93dp"
        android:layout_height="24dp"
        android:layout_marginStart="32dp"
        android:layout_marginTop="340dp"
        android:text="Ambiente"
        android:textColor="@color/verdeF"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Spinner
        android:id="@+id/spnEPTipoP"
        android:layout_width="0dp"
        android:layout_height="48sp"
        android:layout_marginStart="32dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="32dp"
        android:background="@drawable/rounded_spinner_background"
        android:entries="@array/tipo_planta"
        android:popupBackground="@color/fondo2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/etEPTipoP" />

    <ImageView
        android:id="@+id/imgEPPlanta"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:layout_marginStart="32dp"
        android:layout_marginTop="28dp"
        android:background="@color/fondo2"
        android:scaleType="centerCrop"
        app:srcCompat="@android:drawable/gallery_thumb"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/vEPlinea" />

    <TextView
        android:id="@+id/etEPNombre"
        android:layout_width="71dp"
        android:layout_height="22dp"
        android:layout_marginStart="32dp"
        android:layout_marginTop="16dp"
        android:text="Apodo"
        android:textColor="@color/verdeF"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/imgEPPlanta" />

    <EditText
        android:id="@+id/edEPNombre"
        android:layout_width="219dp"
        android:layout_height="48dp"
        android:layout_marginStart="32dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/rounded_edittext_background"
        android:hint="Apodo"
        android:textColorHint="@color/verdeM"
        android:padding="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/etEPNombre" />

    <Button
        android:id="@+id/btnEPtoP"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:backgroundTint="@color/verdeM"
        android:textColor="@color/fondo1"
        android:text="Inicio"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.117"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/btnEPConti"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="40dp"
        android:backgroundTint="@color/verdeM"
        android:text="Continuar"
        android:textColor="@color/fondo1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>