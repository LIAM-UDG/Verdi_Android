<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5DC"
    android:padding="16dp">

    <!-- Header con flecha de regreso y título -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="Regresar" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Alertas en el Sistema"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#8B4513"
            android:gravity="center"
            android:layout_marginEnd="40dp" />

    </LinearLayout>

    <!-- Barra de búsqueda -->
    <EditText
        android:id="@+id/et_buscar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="🔎Buscar fallos"
        android:background="@drawable/search_background"
        android:padding="12dp"
        android:layout_marginBottom="20dp"
        android:drawableStart="@drawable/ic_search"
        android:drawablePadding="10dp"
        android:textColorHint="#3D4224" />

    <!-- ScrollView para las alertas -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/ll_alertas_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Alerta 1: Con rectángulos verdes -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:layout_marginBottom="12dp"
                android:gravity="center_vertical"
                android:background="#A3A151">

                <!-- Rectángulo verde para el texto principal -->
                <View
                    android:layout_width="180dp"
                    android:layout_height="60dp"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/alert_background"
                    android:visibility="visible"
                    tools:visibility="visible" />

                <!-- Rectángulo verde para fecha y categoría -->
                <View
                    android:layout_width="120dp"
                    android:layout_height="60dp"
                    android:background="@drawable/alert_background"
                    android:layout_marginEnd="12dp" />

                <!-- Indicador circular -->
                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/indicator_circle" />

            </LinearLayout>

            <!-- Alerta 2: Fallo de obstrucción -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/alert_background"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">


                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">



                </LinearLayout>

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/indicator_circle"
                    android:layout_marginStart="12dp"
                    android:layout_gravity="center_vertical" />

            </LinearLayout>

            <!-- Alerta 3: Con rectángulos verdes -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:layout_marginBottom="12dp"
                android:gravity="center_vertical">

                <!-- Rectángulo verde para el texto principal -->
                <View
                    android:layout_width="180dp"
                    android:layout_height="60dp"
                    android:background="@drawable/alert_background"
                    android:layout_marginEnd="12dp" />

                <!-- Rectángulo verde para fecha y categoría -->
                <View
                    android:layout_width="120dp"
                    android:layout_height="60dp"
                    android:background="@drawable/alert_background"
                    android:layout_marginEnd="12dp" />

                <!-- Indicador circular -->
                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/indicator_circle" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- Botón Borrar Todo -->
    <Button
        android:id="@+id/btn_borrar_todo"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="16dp"
        android:text="Borrar Todo"
        android:textColor="@android:color/white"
        android:background="@drawable/delete_button_background"
        android:padding="12dp"
        android:drawableEnd="@drawable/ic_delete"
        android:drawablePadding="8dp" />

</LinearLayout>