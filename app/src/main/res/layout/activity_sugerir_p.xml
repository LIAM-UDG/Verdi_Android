<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo1"
    tools:context=".SugerirP">

    <!-- Título -->

    <!-- Línea divisoria -->

    <!-- Imagen de planta (placeholder) -->

    <TextView
        android:id="@+id/etSPTitulo"
        android:layout_width="270dp"
        android:layout_height="44dp"
        android:layout_marginTop="28dp"
        android:fontFamily="serif"
        android:text="Sugerir Planta"
        android:textAlignment="center"
        android:textColor="@color/verdeF"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.496"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/vSPlinea"
        android:layout_width="0dp"
        android:layout_height="2dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="7dp"
        android:background="@color/verdeF"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/etSPTitulo" />

    <ImageView
        android:id="@+id/imgSPPlanta"
        android:layout_width="119dp"
        android:layout_height="118dp"
        android:layout_marginStart="32dp"
        android:layout_marginTop="24dp"
        android:background="@android:color/white"
        android:scaleType="centerCrop"
        android:backgroundTint="@color/fondo2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/vSPlinea" />

    <!-- Botón Subir foto -->
    <Button
        android:id="@+id/btnSPSubFoto"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Subir foto"
        android:backgroundTint="@color/verdeM"
        android:textColor="@color/fondo1"
        app:layout_constraintTop_toBottomOf="@id/vSPlinea"
        app:layout_constraintStart_toEndOf="@id/imgSPPlanta"
        android:layout_marginStart="16dp"
        android:layout_marginTop="60dp" />

    <!-- Etiqueta Nombre -->

    <!-- Campo Nombre -->
    <TextView
        android:id="@+id/etSPNombre"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginTop="28dp"
        android:text="Nombre:"
        android:fontFamily="serif"
        android:textColor="@color/verdeF"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/imgSPPlanta" />

    <EditText
        android:id="@+id/edSPNombre"
        android:layout_width="0dp"
        android:padding="10dp"
        android:layout_height="48dp"
        android:background="@drawable/rounded_edittext_background"
        android:hint="Nombre"
        android:textColorHint="@color/verdeM"
        app:layout_constraintTop_toBottomOf="@id/etSPNombre"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="8dp" />

    <!-- Etiqueta Descripción -->
    <TextView
        android:id="@+id/etSPDescrip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Descripción:"
        android:fontFamily="serif"
        android:textColor="@color/verdeF"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/edSPNombre"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="24dp"
        android:layout_marginStart="32dp" />

    <!-- Campo Descripción -->
    <EditText
        android:id="@+id/edSPDescrip"
        android:layout_width="0dp"
        android:layout_height="120dp"
        android:background="@drawable/rounded_edittext_background"
        android:hint="-Área donde se encuentre\n-Clima\n-Color\n-Etc."
        android:textColorHint="@color/verdeM"
        android:gravity="top|start"
        android:padding="10dp"
        app:layout_constraintTop_toBottomOf="@id/etSPDescrip"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="8dp" />

    <!-- Botón Continuar -->
    <Button
        android:id="@+id/btnSPConti"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Continuar"
        android:backgroundTint="@color/verdeM"
        android:textColor="@color/fondo1"
        app:layout_constraintTop_toBottomOf="@id/edSPDescrip"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="32dp" />

    <!-- Botón Atrás -->
    <Button
        android:id="@+id/btnSPtoP"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Atrás"
        android:backgroundTint="@color/verdeM"
        android:textColor="@color/fondo1"
        app:layout_constraintTop_toBottomOf="@id/edSPDescrip"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="24dp"
        android:layout_marginStart="32dp" />

</androidx.constraintlayout.widget.ConstraintLayout>