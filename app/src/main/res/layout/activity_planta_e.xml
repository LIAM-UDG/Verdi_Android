<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo1"
    tools:context=".PlantaE">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        >


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:padding="10dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/epleTitulo"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:fontFamily="serif"
                android:text="Cargando planta..."
                android:textColor="@color/verdeF"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/epleBarrita"
                android:layout_width="380dp"
                android:layout_height="2dp"
                android:text=""
                android:background="@color/verdeF"/>

            <ImageView
                android:id="@+id/imPlan"
                android:layout_width="188dp"
                android:layout_height="193dp"
                android:padding="-30dp"
                app:srcCompat="@android:drawable/gallery_thumb" />

            <TextView
                android:id="@+id/epleDescrip"
                android:layout_width="match_parent"
                android:layout_height="33dp"
                android:fontFamily="serif"
                android:text="Descripción"
                android:textColor="@color/verdeF"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/epleDescText"
                android:layout_width="match_parent"
                android:layout_height="424dp"
                android:fontFamily="serif"
                android:text="Cargando descripción..."
                android:textColor="@color/verdeF"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/epleCuidados"
                android:layout_width="match_parent"
                android:layout_height="33dp"
                android:fontFamily="serif"
                android:text="Cuidados"
                android:textColor="@color/verdeF"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/epleCuidadText"
                android:layout_width="match_parent"
                android:layout_height="192dp"
                android:fontFamily="serif"
                android:text="Cargando cuidados..."
                android:textColor="@color/verdeF"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/epleUsos"
                android:layout_width="match_parent"
                android:layout_height="33dp"
                android:fontFamily="serif"
                android:text="Usos"
                android:textColor="@color/verdeF"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/epleUsoText"
                android:layout_width="match_parent"
                android:layout_height="215dp"
                android:fontFamily="serif"
                android:text="Cargando usos..."
                android:textColor="@color/verdeF"
                android:textSize="20sp" />

            <Button
                android:id="@+id/bplePletoEn"
                android:layout_width="105dp"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/verdeM"
                android:text="Atrás" />


        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>