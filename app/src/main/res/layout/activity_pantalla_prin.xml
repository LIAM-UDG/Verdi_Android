<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo1"
    tools:context=".PantallaPrin">

    <TextView
        android:id="@+id/epTitulo"
        android:layout_width="231dp"
        android:layout_height="45dp"
        android:layout_marginTop="40dp"
        android:fontFamily="serif"
        android:text="Loth Garder"
        android:textAlignment="center"
        android:textColor="@color/verdeF"
        android:textSize="35sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/bpPtoU"
        android:layout_width="346dp"
        android:layout_height="57dp"
        android:layout_marginTop="152dp"
        android:backgroundTint="@color/verdeM"
        android:text="Perfil de Usuario"
        android:textColor="@color/fondo1"
        app:icon="@android:mipmap/sym_def_app_icon"
        app:iconTint="@color/fondo1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.491"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/bpPtoE"
        android:layout_width="346dp"
        android:layout_height="57dp"
        android:layout_marginTop="244dp"
        android:backgroundTint="@color/verdeM"
        android:text="Enciclopedia"
        android:textColor="@color/fondo1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.491"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/bpPtoPU"
        android:layout_width="346dp"
        android:layout_height="57dp"
        android:layout_marginTop="336dp"
        android:backgroundTint="@color/verdeM"
        android:text="Plantas de Usuario"
        android:textColor="@color/fondo1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.491"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/bpPtoEst"
        android:layout_width="346dp"
        android:layout_height="57dp"
        android:layout_marginTop="428dp"
        android:backgroundTint="@color/verdeM"
        android:text="Estadisticas de Sistema"
        android:textColor="@color/fondo1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.491"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/bpPtoSop"
        android:layout_width="346dp"
        android:layout_height="57dp"
        android:layout_marginTop="524dp"
        android:backgroundTint="@color/verdeM"
        android:text="Soporte"
        android:textColor="@color/fondo1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.491"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/bpPtoMain"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="644dp"
        android:backgroundTint="@color/verdeM"
        android:text="Salir"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.086"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>