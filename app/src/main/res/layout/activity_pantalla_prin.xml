<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo1"
    android:backgroundTint="@color/fondo1"
    tools:context=".PantallaPrin">

    <ImageView
        android:id="@+id/bpPtoL"
        android:layout_width="45dp"
        android:layout_height="43dp"
        android:layout_marginBottom="16dp"
        android:src="@drawable/logro"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.956"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageView
        android:id="@+id/bpPtoB"
        android:layout_width="45dp"
        android:layout_height="43dp"
        android:layout_marginBottom="16dp"
        android:src="@drawable/busqueda"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.653"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageView
        android:id="@+id/bpPtoA"
        android:layout_width="45dp"
        android:layout_height="43dp"
        android:layout_marginBottom="16dp"
        android:src="@drawable/alertas"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.803"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/epTitulo"
        android:layout_width="270dp"
        android:layout_height="60dp"
        android:layout_marginTop="40dp"
        android:fontFamily="serif"
        android:text="Verdi"
        android:shadowColor="@color/verdeM"
        android:shadowDx="2"
        android:shadowDy="2"
        android:shadowRadius="5"
        android:textAlignment="center"
        android:textColor="@color/verdeF"
        android:textSize="50sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />



    <Button
        android:id="@+id/bpPtoU"
        android:layout_width="350dp"
        android:layout_height="60dp"
        android:layout_marginTop="150dp"
        android:backgroundTint="@color/verdeM"
        android:text="Perfil de Usuario"
        android:textColor="@color/fondo1"
        android:textSize="17sp"
        app:icon="@drawable/perfil"
        app:iconTint="@color/fondo1"
        android:elevation="30dp"
        android:translationZ="13dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.491"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/bpPtoE"
        android:layout_width="350dp"
        android:layout_height="60dp"
        android:layout_marginTop="35dp"
        android:backgroundTint="@color/verdeM"
        android:text="Enciclopedia"
        android:textColor="@color/fondo1"
        android:textSize="17sp"
        app:icon="@drawable/enciclopedia"
        app:iconTint="@color/fondo1"
        android:elevation="30dp"
        android:translationZ="13dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.524"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/bpPtoU" />

    <Button
        android:id="@+id/bpPtoPU"
        android:layout_width="350dp"
        android:layout_height="60dp"
        android:layout_marginTop="35dp"
        android:backgroundTint="@color/verdeM"
        android:text="Plantas de Usuario"
        android:textColor="@color/fondo1"
        android:textSize="17sp"
        app:icon="@drawable/planta"
        app:iconTint="@color/fondo1"
        android:elevation="30dp"
        android:translationZ="13dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.49"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/bpPtoE" />

    <Button
        android:id="@+id/bpPtoEst"
        android:layout_width="350dp"
        android:layout_height="60dp"
        android:layout_marginTop="35dp"
        android:backgroundTint="@color/verdeM"
        android:text="Sistema de Usuario"
        android:textColor="@color/fondo1"
        android:textSize="17sp"
        app:icon="@drawable/baseline_developer_board_24"
        app:iconTint="@color/fondo1"
        android:elevation="30dp"
        android:translationZ="13dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.43"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/bpPtoPU" />

    <Button
        android:id="@+id/bpPtoSop"
        android:layout_width="350dp"
        android:layout_height="60dp"
        android:layout_marginTop="35dp"
        android:backgroundTint="@color/verdeM"
        android:text="Soporte"
        android:textColor="@color/fondo1"
        android:textSize="17sp"
        app:icon="@android:drawable/ic_dialog_info"
        app:iconTint="@color/fondo1"
        android:elevation="30dp"
        android:translationZ="13dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.43"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/bpPtoEst" />

    <Button
        android:id="@+id/bpPtoMain"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="644dp"
        android:backgroundTint="@color/verdeM"
        android:text="Salir"
        android:textColor="@color/fondo1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.086"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/linea1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="36dp"
        android:width="90dp"
        android:height="2dp"
        android:background="@color/verdeF"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.118"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/epTitulo" />

    <TextView
        android:id="@+id/linea2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="36dp"
        android:width="90dp"
        android:height="2dp"
        android:background="@color/verdeF"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.884"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/epTitulo" />

</androidx.constraintlayout.widget.ConstraintLayout>