<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo1"
    tools:context=".NuevaP">

    <!-- Título -->
    <TextView
        android:id="@+id/tvTitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nueva Planta"
        android:textColor="@color/verdeF"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="16dp" />

    <!-- Línea divisoria -->
    <View
        android:id="@+id/linea"
        android:layout_width="0dp"
        android:layout_height="2dp"
        android:background="@color/verdeF"
        app:layout_constraintTop_toBottomOf="@id/tvTitulo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="16dp" />

    <!-- Imagen de planta (placeholder) -->
    <ImageView
        android:id="@+id/imgPlanta"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:background="@android:color/white"
        android:scaleType="centerCrop"
        app:layout_constraintTop_toBottomOf="@id/linea"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="32dp"
        android:layout_marginTop="24dp" />

    <!-- Botón Subir foto -->
    <Button
        android:id="@+id/btnSubirFoto"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Subir foto"
        android:backgroundTint="@color/verdeM"
        android:textColor="@android:color/white"
        app:layout_constraintTop_toBottomOf="@id/linea"
        app:layout_constraintStart_toEndOf="@id/imgPlanta"
        android:layout_marginStart="16dp"
        android:layout_marginTop="60dp" />

    <!-- Etiqueta Nombre -->
    <TextView
        android:id="@+id/tvNombre"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nombre:"
        android:textColor="@color/verdeF"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/imgPlanta"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="24dp"
        android:layout_marginStart="32dp" />

    <!-- Campo Nombre -->
    <EditText
        android:id="@+id/etNombre"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#E6E2C4"
        app:layout_constraintTop_toBottomOf="@id/tvNombre"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnSeleccionarPlanta"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginTop="8dp"
        android:padding="8dp" />

    <!-- Botón Seleccionar Planta -->
    <Button
        android:id="@+id/btnSeleccionarPlanta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Seleccionar Planta"
        android:backgroundTint="@color/verdeM"
        android:textColor="@android:color/white"
        app:layout_constraintTop_toBottomOf="@id/tvNombre"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="32dp"
        android:layout_marginTop="8dp" />

    <!-- Etiqueta Especie -->
    <TextView
        android:id="@+id/tvEspecie"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Especie:"
        android:textColor="@color/verdeF"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/etNombre"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="24dp"
        android:layout_marginStart="32dp" />

    <!-- Campo Especie -->
    <EditText
        android:id="@+id/etEspecie"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#E6E2C4"
        app:layout_constraintTop_toBottomOf="@id/tvEspecie"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnSeleccionarPlantaEspecie"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginTop="8dp"
        android:padding="8dp" />

    <!-- Botón Seleccionar Planta (Especie) -->
    <Button
        android:id="@+id/btnSeleccionarPlantaEspecie"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Seleccionar Planta"
        android:backgroundTint="@color/verdeM"
        android:textColor="@android:color/white"
        app:layout_constraintTop_toBottomOf="@id/tvEspecie"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="32dp"
        android:layout_marginTop="8dp" />

    <!-- Etiqueta Tiempo -->
    <TextView
        android:id="@+id/tvTiempo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="¿Cuánto tiempo tienes con tu planta?"
        android:textColor="@color/verdeF"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/etEspecie"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="24dp"
        android:layout_marginStart="32dp" />

    <!-- Botón Seleccionar Tiempo -->
    <Button
        android:id="@+id/btnSeleccionarTiempo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Seleccionar"
        android:backgroundTint="@color/verdeM"
        android:textColor="@android:color/white"
        app:layout_constraintTop_toBottomOf="@id/tvTiempo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginTop="8dp" />

    <!-- Etiqueta Ambiente -->
    <TextView
        android:id="@+id/tvAmbiente"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ambiente"
        android:textColor="@color/verdeF"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/btnSeleccionarTiempo"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="24dp"
        android:layout_marginStart="32dp" />

    <!-- Botón Seleccionar Ambiente -->
    <Button
        android:id="@+id/btnSeleccionarAmbiente"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Seleccionar"
        android:backgroundTint="@color/verdeM"
        android:textColor="@android:color/white"
        app:layout_constraintTop_toBottomOf="@id/tvAmbiente"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginTop="8dp" />

    <!-- Botón Continuar -->
    <Button
        android:id="@+id/btnContinuar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Continuar"
        android:backgroundTint="@color/verdeM"
        android:textColor="@android:color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="32dp"
        android:layout_marginEnd="32dp" />

</androidx.constraintlayout.widget.ConstraintLayout>