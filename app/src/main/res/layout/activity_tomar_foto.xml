<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".TomarFoto">

    <androidx.camera.view.PreviewView
        android:id="@+id/vpTFPrevi"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />


    <TextView
        android:id="@+id/etTFIndica"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Toma la foto dentro del cuadro blanco"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:padding="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="80dp"/>

    <!-- ARRIBA -->
    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#80000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/viewEncuedre"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ABAJO -->
    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#80000000"
        app:layout_constraintTop_toBottomOf="@id/viewEncuedre"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- IZQUIERDA -->
    <View
        android:layout_width="0dp"
        android:layout_height="300dp"
        android:background="#80000000"
        app:layout_constraintTop_toTopOf="@id/viewEncuedre"
        app:layout_constraintBottom_toBottomOf="@id/viewEncuedre"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/viewEncuedre"/>

    <!-- DERECHA -->
    <View
        android:layout_width="0dp"
        android:layout_height="300dp"
        android:background="#80000000"
        app:layout_constraintTop_toTopOf="@id/viewEncuedre"
        app:layout_constraintBottom_toBottomOf="@id/viewEncuedre"
        app:layout_constraintStart_toEndOf="@id/viewEncuedre"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- CUADRO CENTRAL -->
    <View
        android:id="@+id/viewEncuedre"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:background="@drawable/encuadre_foto"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnTFCapturar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:contentDescription="Tomar foto"
        app:srcCompat="@android:drawable/ic_menu_camera"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:backgroundTint="@color/white" />



</androidx.constraintlayout.widget.ConstraintLayout>