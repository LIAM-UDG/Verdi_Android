<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo1"
    tools:context=".PlantaU">

    <TextView
        android:id="@+id/epluTitulo"
        android:layout_width="322dp"
        android:layout_height="47dp"
        android:layout_marginTop="48dp"
        android:fontFamily="serif"
        android:text=""
        android:textAlignment="center"
        android:textColor="@color/verdeF"
        android:textSize="30sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.056"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/eplubarrita"
        android:layout_width="380dp"
        android:layout_height="2dp"
        android:layout_marginTop="92dp"
        android:background="@color/verdeF"
        android:text=""
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.483"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/eplubarrita2"
        android:layout_width="250dp"
        android:layout_height="2dp"
        android:layout_marginTop="332dp"
        android:background="@color/verdeF"
        android:text=""
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/imPlan"
        android:layout_width="188dp"
        android:layout_height="193dp"
        android:padding="-30dp"
        app:srcCompat="@android:drawable/gallery_thumb"
        tools:layout_editor_absoluteX="16dp"
        tools:layout_editor_absoluteY="104dp"
        tools:ignore="MissingConstraints" />

    <TextView
        android:id="@+id/epluEstado"
        android:layout_width="70dp"
        android:layout_height="26dp"
        android:layout_marginTop="352dp"
        android:fontFamily="serif"
        android:text="Estado:"
        android:textAlignment="textStart"
        android:textColor="@color/verdeF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.038"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/epluTexto"
        android:layout_width="157dp"
        android:layout_height="32dp"
        android:layout_marginTop="316dp"
        android:fontFamily="serif"
        android:text="Datos de la planta"
        android:textAlignment="textStart"
        android:textColor="@color/verdeF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.046"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/epluEstado3"
        android:layout_width="70dp"
        android:layout_height="26dp"
        android:layout_marginTop="352dp"
        android:fontFamily="serif"
        android:text="Estado:"
        android:textAlignment="textStart"
        android:textColor="@color/verdeF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.038"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/epluTemp"
        android:layout_width="115dp"
        android:layout_height="26dp"
        android:layout_marginTop="384dp"
        android:fontFamily="serif"
        android:text="Temperatura:"
        android:textAlignment="textStart"
        android:textColor="@color/verdeF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.05"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/epluHume"
        android:layout_width="91dp"
        android:layout_height="27dp"
        android:layout_marginTop="428dp"
        android:fontFamily="serif"
        android:text="Humedad:"
        android:textAlignment="textStart"
        android:textColor="@color/verdeF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.05"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/epluLugar"
        android:layout_width="70dp"
        android:layout_height="26dp"
        android:layout_marginTop="476dp"
        android:fontFamily="serif"
        android:text="Lugar:"
        android:textAlignment="textStart"
        android:textColor="@color/verdeF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.046"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/epluAgua"
        android:layout_width="140dp"
        android:layout_height="28dp"
        android:layout_marginTop="516dp"
        android:fontFamily="serif"
        android:text="Agua utilizada:"
        android:textAlignment="textStart"
        android:textColor="@color/verdeF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.046"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/bpluPlutoPrin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="644dp"
        android:backgroundTint="@color/verdeM"
        android:text="Inicio"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.086"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>